<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/sheet_rounded_bg"
    android:paddingTop="8dp"
    android:paddingBottom="18dp">

    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="2dp"
        android:layout_marginBottom="12dp"
        android:background="@drawable/sheet_handle_bg" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingBottom="12dp">

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/ivSongActionCover"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:background="#FFF2F2F2"
            android:contentDescription="专辑封面"
            android:scaleType="centerCrop"
            android:src="@drawable/music_note_24"
            app:shapeAppearanceOverlay="@style/ShapeCover"
            app:strokeColor="@color/cover_frame_default"
            app:strokeWidth="1.3dp" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="14dp"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvSongActionTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:singleLine="true"
                android:ellipsize="end"
                android:textSize="19sp"
                android:textStyle="normal"
                android:textColor="#FF000000"
                tools:text="歌曲名称" />

            <TextView
                android:id="@+id/tvSongActionArtist"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:singleLine="true"
                android:ellipsize="end"
                android:textSize="15sp"
                android:textColor="#FF444444"
                tools:text="歌手" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/tvSongActionAlbum"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:singleLine="true"
                    android:ellipsize="end"
                    android:textSize="13sp"
                    android:textColor="#FF777777"
                    tools:text="歌曲所在专辑" />

                <TextView
                    android:id="@+id/tvSongActionQualityBadge"
                    android:layout_width="wrap_content"
                    android:layout_height="16dp"
                    android:layout_marginStart="6dp"
                    android:background="@drawable/quality_badge_bg"
                    android:gravity="center"
                    android:includeFontPadding="false"
                    android:minWidth="24dp"
                    android:paddingStart="4dp"
                    android:paddingEnd="4dp"
                    android:textColor="#FF1565C0"
                    android:textSize="9sp"
                    android:textStyle="bold"
                    android:visibility="gone"
                    tools:text="HR"
                    tools:visibility="visible" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageButton
                android:id="@+id/btnSongActionShare"
                android:layout_width="26dp"
                android:layout_height="26dp"
                android:background="@android:color/transparent"
                android:contentDescription="分享"
                android:padding="1dp"
                android:scaleType="centerInside"
                android:src="@drawable/ic_share_24" />

            <ImageButton
                android:id="@+id/btnSongActionFavorite"
                android:layout_width="26dp"
                android:layout_height="26dp"
                android:layout_marginStart="12dp"
                android:background="@android:color/transparent"
                android:contentDescription="收藏"
                android:scaleType="centerInside"
                android:src="@drawable/ic_favorite_black_custom" />
        </LinearLayout>
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:layout_marginTop="4dp"
        android:background="#FFE6E6E6" />

    <LinearLayout
        android:id="@+id/rowSongActionPlayNext"
        android:layout_width="match_parent"
        android:layout_height="58dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:background="?attr/selectableItemBackground"
        android:paddingStart="20dp"
        android:paddingEnd="20dp">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_play_next_custom"
            android:contentDescription="下一首播放" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="16dp"
            android:text="下一首播放"
            android:textColor="#FF000000"
            android:textSize="15sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/rowSongActionAppendAndPlay"
        android:layout_width="match_parent"
        android:layout_height="58dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:background="?attr/selectableItemBackground"
        android:paddingStart="20dp"
        android:paddingEnd="20dp">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_playlist_play_outline"
            android:contentDescription="追加并播放" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="16dp"
            android:text="追加并播放"
            android:textColor="#FF000000"
            android:textSize="15sp" />
    </LinearLayout>

    <!-- 添加到歌单：弹出歌单选择器，用户挑一个把这首歌加入 -->
    <LinearLayout
        android:id="@+id/rowSongActionAddToPlaylist"
        android:layout_width="match_parent"
        android:layout_height="58dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:background="?attr/selectableItemBackground"
        android:paddingStart="20dp"
        android:paddingEnd="20dp">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/add_circle_24"
            android:contentDescription="添加到歌单" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="16dp"
            android:text="添加到歌单"
            android:textColor="#FF000000"
            android:textSize="15sp" />
    </LinearLayout>


    <!-- 设置铃声：打开统一样式的铃声片段编辑抽屉 -->
    <LinearLayout
        android:id="@+id/rowSongActionSetRingtone"
        android:layout_width="match_parent"
        android:layout_height="58dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:background="?attr/selectableItemBackground"
        android:paddingStart="20dp"
        android:paddingEnd="20dp">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_notifications_24"
            android:contentDescription="设置铃声" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="16dp"
            android:text="设置铃声"
            android:textColor="#FF000000"
            android:textSize="15sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/rowSongActionDelete"
        android:layout_width="match_parent"
        android:layout_height="58dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:background="?attr/selectableItemBackground"
        android:paddingStart="20dp"
        android:paddingEnd="20dp">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_delete_24"
            android:contentDescription="删除" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="16dp"
            android:text="删除"
            android:textColor="#FFD32F2F"
            android:textSize="15sp" />
    </LinearLayout>

    <!-- 从当前歌单移除：只在从歌单详情页进来时才 VISIBLE -->
    <LinearLayout
        android:id="@+id/rowSongActionRemoveFromPlaylist"
        android:layout_width="match_parent"
        android:layout_height="58dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:background="?attr/selectableItemBackground"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:visibility="gone">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_close_24"
            android:contentDescription="从歌单移除" />

        <TextView
            android:id="@+id/tvSongActionRemoveFromPlaylist"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="16dp"
            android:text="从歌单移除"
            android:textColor="#FFD32F2F"
            android:textSize="15sp" />
    </LinearLayout>

</LinearLayout>
