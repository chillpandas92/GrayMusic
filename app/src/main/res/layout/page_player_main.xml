<?xml version="1.0" encoding="utf-8"?>
<!--
  Edge-to-Edge / Window Insets 说明：
  - playerRoot 背景白色：由 playerBackdropOverlay 负责整屏上色（渐变），
    它会一直延伸到状态栏 / 导航栏之下（0dp + 四边 parent 约束）。
  - 不再使用独立的 scrim View ——渐变 overlay 顶色和底色已经是 alpha 255，
    完全覆盖系统栏区域，不需要额外叠一层实色；叠了反而会在 scrim 边缘产生断层。
  - window.statusBarColor / navigationBarColor 保持透明，颜色全由 overlay 绘制。
-->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/playerMainPageRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="false"
    android:background="@android:color/transparent">


    <!-- 顶部：关闭（向下箭头） -->
    <ImageButton
        android:id="@+id/btnPlayerCloseAnchor"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:layout_marginStart="12dp"
        android:layout_marginTop="12dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:src="@drawable/ic_expand_more_24"
        android:scaleType="center"
        android:contentDescription="@null"
        android:visibility="invisible"
        android:clickable="false"
        android:focusable="false"
        android:importantForAccessibility="no"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- 封面容器：严格正方形（1:1） -->
    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/ivPlayerCover"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="32dp"
        android:layout_marginEnd="32dp"
        android:layout_marginTop="4dp"
        android:background="#FFF2F2F2"
        android:elevation="10dp"
        android:scaleType="centerCrop"
        android:src="@drawable/music_note_24"
        android:contentDescription="cover"
        app:layout_constraintTop_toBottomOf="@id/btnPlayerCloseAnchor"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintDimensionRatio="H,1:1"
        app:shapeAppearanceOverlay="@style/ShapeCover"
        app:strokeColor="@color/cover_frame_default"
        app:strokeWidth="1.3dp" />

    <!-- 歌名 + 收藏 -->
    <LinearLayout
        android:id="@+id/playerTitleRow"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="32dp"
        android:layout_marginEnd="32dp"
        android:layout_marginTop="28dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        app:layout_constraintTop_toBottomOf="@id/ivPlayerCover"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/tvPlayerTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="12dp"
            android:textSize="20sp"
            android:textStyle="normal"
            android:textColor="#FF000000"
            android:singleLine="true"
            android:ellipsize="marquee"
            android:marqueeRepeatLimit="marquee_forever"
            android:scrollHorizontally="true"
            android:paddingEnd="4dp"
            android:focusable="true"
            android:focusableInTouchMode="true"
            tools:text="歌曲名称" />

        <ImageButton
            android:id="@+id/btnPlayerFavorite"
            android:layout_width="26dp"
            android:layout_height="26dp"
            android:layout_marginStart="10dp"
            android:background="@android:color/transparent"
            android:src="@drawable/ic_favorite_black_custom"
            android:scaleType="centerInside"
            android:contentDescription="收藏" />

    </LinearLayout>

    <!-- 歌手 -->
    <TextView
        android:id="@+id/tvPlayerArtist"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="32dp"
        android:layout_marginEnd="32dp"
        android:layout_marginTop="4dp"
        android:textSize="14sp"
        android:textColor="#FF888888"
        android:singleLine="true"
        android:ellipsize="end"
        tools:text="歌手"
        app:layout_constraintTop_toBottomOf="@id/playerTitleRow"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <LinearLayout
        android:id="@+id/playerLyricPreviewGroup"
        android:layout_width="0dp"
        android:layout_height="48dp"
        android:layout_marginStart="32dp"
        android:layout_marginEnd="32dp"
        android:layout_marginTop="14dp"
        android:orientation="vertical"
        android:visibility="visible"
        app:layout_constraintTop_toBottomOf="@id/tvPlayerArtist"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.example.localmusicapp.KaraokeLyricTextView
            android:id="@+id/tvPlayerLyricPreviewLine1"
            android:layout_width="match_parent"
            android:layout_height="22dp"
            android:maxLines="1"
            android:ellipsize="end"
            android:textSize="15sp"
            android:textColor="#D8000000"
            tools:text="第一行歌词" />

        <com.example.localmusicapp.KaraokeLyricTextView
            android:id="@+id/tvPlayerLyricPreviewLine2"
            android:layout_width="match_parent"
            android:layout_height="22dp"
            android:layout_marginTop="4dp"
            android:maxLines="1"
            android:ellipsize="end"
            android:textSize="14sp"
            android:textColor="#98000000"
            tools:text="第二行歌词" />

    </LinearLayout>

    <!--
      进度条：
      - 黑色圆角进度，视觉高度 4dp（由 maxHeight 决定）
      - 外层 layout_height 给到 32dp 是为了放大命中区域，手指不用贴着细线才能按中。
        SeekBar 会把进度 drawable 垂直居中在这 32dp 里，所以看起来和原来一样，但点哪都点得到。
    -->
    <SeekBar
        android:id="@+id/playerSeekBar"
        android:layout_width="0dp"
        android:layout_height="32dp"
        android:layout_marginStart="32dp"
        android:layout_marginEnd="32dp"
        android:layout_marginTop="34dp"
        android:background="@null"
        android:max="1000"
        android:progressDrawable="@drawable/player_seekbar_progress"
        android:thumb="@null"
        android:thumbOffset="0dp"
        android:splitTrack="false"
        android:minHeight="4dp"
        android:maxHeight="4dp"
        android:paddingStart="0dp"
        android:paddingEnd="0dp"
        app:layout_constraintTop_toBottomOf="@id/playerLyricPreviewGroup"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!--
      时间（当前 / 剩余倒计时）—— margin 32dp 与进度条/封面对齐，文字不超出进度条。
      marginTop 用负值把时间行往进度条方向拉近：
      SeekBar 视觉高度只有 4dp，但外层 32dp 是为了加大手指命中区，
      4dp 进度条垂直居中时上下各有约 14dp 的空白。
      这里让时间行往上"吃掉"一部分这段空白，
      视觉上把 进度条 ↔ 时间 的距离从约 24dp 收紧到 8dp 左右，
      同时触摸命中区完全不受影响。
    -->
    <LinearLayout
        android:id="@+id/playerTimeRow"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginStart="32dp"
        android:layout_marginEnd="32dp"
        android:layout_marginTop="-6dp"
        app:layout_constraintTop_toBottomOf="@id/playerSeekBar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/tvPlayerCurrentTime"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="00:00"
            android:textSize="12sp"
            android:textColor="#FF888888" />

        <!-- 右侧：剩余时间倒计时 -->
        <TextView
            android:id="@+id/tvPlayerTotalTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="-00:00"
            android:textSize="12sp"
            android:textColor="#FF888888" />
    </LinearLayout>

    <!--
      控制栏：底部按钮整体向上移动
      marginTop 从 72dp 改为 28dp
    -->
    <LinearLayout
        android:id="@+id/playerControls"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:layout_marginTop="20dp"
        app:layout_constraintTop_toBottomOf="@id/playerTimeRow"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- 播放模式 -->
        <ImageButton
            android:id="@+id/btnPlayerMode"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/shuffle_24"
            android:scaleType="center"
            android:contentDescription="播放模式" />

        <View
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1" />

        <!--
          上一曲：fast_rewind_24（双左箭头，rounded corners）
          按用户要求改成 ImageView，设置 clickable+focusable
        -->
        <ImageView
            android:id="@+id/btnPlayerPrev"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:layout_marginEnd="18dp"
            android:padding="2dp"
            android:src="@drawable/ic_skip_to_start_custom"
            android:scaleType="center"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="上一曲" />

        <!-- 播放/暂停（大圆按钮 · Lottie 动画 + 静态覆盖层）-->
        <FrameLayout
            android:id="@+id/btnPlayerPlayPauseWrap"
            android:layout_width="68dp"
            android:layout_height="68dp"
            android:layout_marginStart="0dp"
            android:layout_marginEnd="0dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true"
            android:contentDescription="播放/暂停">

            <com.airbnb.lottie.LottieAnimationView
                android:id="@+id/btnPlayerPlayPause"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:padding="0dp"
                android:scaleType="centerInside"
                android:visibility="invisible"
                app:lottie_rawRes="@raw/icons8_pause"
                app:lottie_autoPlay="false"
                app:lottie_loop="false" />

            <ImageView
                android:id="@+id/btnPlayerPlayPauseStatic"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:padding="0dp"
                android:scaleType="centerInside"
                android:src="@drawable/ic_pause_custom" />

        </FrameLayout>

        <!--
          下一曲：fast_forward_24（双右箭头，rounded corners）
        -->
        <ImageView
            android:id="@+id/btnPlayerNext"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:layout_marginStart="18dp"
            android:padding="2dp"
            android:src="@drawable/ic_end_custom"
            android:scaleType="center"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="下一曲" />

        <View
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1" />

        <!-- 播放列表 -->
        <ImageButton
            android:id="@+id/btnPlayerQueue"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/queue_music_24"
            android:scaleType="center"
            android:contentDescription="播放列表" />
    </LinearLayout>


    <TextView
        android:id="@+id/tvPlayerNextTrackHint"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="32dp"
        android:layout_marginEnd="32dp"
        android:layout_marginBottom="34dp"
        android:alpha="0"
        android:ellipsize="end"
        android:gravity="center"
        android:maxLines="1"
        android:textColor="#AA000000"
        android:textSize="12sp"
        android:visibility="invisible"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <View
        android:id="@+id/playerBottomAccent"
        android:visibility="gone"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="32dp"
        android:layout_marginEnd="32dp"
        android:layout_marginBottom="18dp"
        android:background="@android:color/transparent"
        android:importantForAccessibility="no"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
