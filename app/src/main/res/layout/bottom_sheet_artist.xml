<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/sheet_rounded_bg"
    android:orientation="vertical">

    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="14dp"
        android:background="@drawable/sheet_handle_bg" />

    <androidx.core.widget.NestedScrollView
        android:id="@+id/artistSheetScroll"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:clipToPadding="false"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:paddingBottom="30dp">

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/ivArtistSheetCover"
                android:layout_width="104dp"
                android:layout_height="104dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="12dp"
                android:background="#FFF2F2F2"
                android:contentDescription="artist cover"
                android:scaleType="centerCrop"
                android:src="@drawable/music_note_24"
                app:shapeAppearanceOverlay="@style/ShapeCircle"
                app:strokeColor="@color/cover_frame_default"
                app:strokeWidth="1.3dp" />

            <TextView
                android:id="@+id/tvArtistSheetName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:gravity="center"
                android:textColor="#FF000000"
                android:textSize="22sp"
                android:textStyle="normal"
                android:singleLine="true"
                android:ellipsize="end"
                tools:text="歌手名" />

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="22dp"
                android:clipToPadding="false"
                android:overScrollMode="never"
                android:scrollbars="none">

                <LinearLayout
                    android:id="@+id/artistAlbumsContainer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal" />
            </HorizontalScrollView>

            <TextView
                android:id="@+id/tvArtistSheetSongsMeta"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:gravity="start"
                android:textColor="#FF000000"
                android:textSize="15sp"
                android:textStyle="normal"
                tools:text="12首歌曲 / 1时24分" />

            <View
                android:layout_width="match_parent"
                android:layout_height="0.5dp"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="8dp"
                android:background="#FFE4E4E4" />

            <LinearLayout
                android:id="@+id/artistSheetTracksContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</LinearLayout>
