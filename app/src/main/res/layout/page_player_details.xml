<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/playerDetailPageRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/transparent"
    android:paddingTop="60dp"
    android:paddingBottom="28dp">

    <LinearLayout
        android:id="@+id/playerDetailContent"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="32dp"
        android:layout_marginEnd="32dp"
        android:orientation="vertical"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/tvPlayerDetailTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:maxLines="2"
            android:textColor="#FF000000"
            android:textSize="24sp"
            tools:text="歌曲名称" />

        <TextView
            android:id="@+id/tvPlayerDetailYear"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:textColor="#FF7A7A7A"
            android:textSize="14sp"
            tools:text="发行年份：2024" />

        <LinearLayout
            android:id="@+id/playerDetailArtistRow"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:layout_marginTop="8dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackground">

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/ivPlayerDetailArtistCover"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:background="#FFF2F2F2"
                android:scaleType="centerCrop"
                android:src="@drawable/music_note_24"
                android:contentDescription="歌手封面"
                app:shapeAppearanceOverlay="@style/ShapeCircle" />

            <TextView
                android:id="@+id/tvPlayerDetailArtist"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:layout_weight="1"
                android:ellipsize="end"
                android:maxLines="1"
                android:textColor="#FF7A7A7A"
                android:textSize="15sp"
                tools:text="歌手" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/playerDetailAlbumRow"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:layout_marginTop="2dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackground">

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/ivPlayerDetailAlbumCover"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:background="#FFF2F2F2"
                android:scaleType="centerCrop"
                android:src="@drawable/music_note_24"
                android:contentDescription="专辑封面"
                app:shapeAppearanceOverlay="@style/ShapeCover" />

            <TextView
                android:id="@+id/tvPlayerDetailAlbum"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:layout_weight="1"
                android:ellipsize="end"
                android:maxLines="1"
                android:textColor="#FF7A7A7A"
                android:textSize="15sp"
                tools:text="专辑" />

        </LinearLayout>

        <!-- AI 锐评：圆角卡片。关闭时整块隐藏。 -->
        <LinearLayout
            android:id="@+id/playerDetailAiCritiqueGroup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:orientation="vertical"
            android:background="@drawable/ai_critique_card_bg"
            android:padding="14dp"
            android:visibility="gone"
            tools:visibility="visible">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="AI 锐评"
                    android:textColor="#FF000000"
                    android:textSize="14sp" />

                <com.airbnb.lottie.LottieAnimationView
                    android:id="@+id/swPlayerDetailAiCritique"
                    android:layout_width="58dp"
                    android:layout_height="32dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:scaleType="fitCenter"
                    app:lottie_autoPlay="false"
                    app:lottie_loop="false"
                    app:lottie_rawRes="@raw/icons8_on_off"
                    android:contentDescription="AI 锐评开关" />

            </LinearLayout>

            <TextView
                android:id="@+id/tvPlayerDetailAiCritique"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:lineSpacingExtra="4dp"
                android:textColor="#FF4A4A4A"
                android:textSize="14sp"
                tools:text="锐评正文……" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/playerDetailProductionGroup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:orientation="vertical"
            android:visibility="gone"
            tools:visibility="visible">

            <TextView
                android:id="@+id/tvPlayerDetailProductionLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="制作"
                android:textColor="#FF000000"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tvPlayerDetailProductionValue"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:lineSpacingExtra="2dp"
                android:textColor="#FF7A7A7A"
                android:textSize="14sp"
                tools:text="作词：XX  作曲：YY" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/playerDetailFileInfoGroup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvPlayerDetailFileInfoLabel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="文件详情"
                android:textColor="#FF000000"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tvPlayerDetailFileInfoValue"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:lineSpacingExtra="2dp"
                android:textColor="#FF7A7A7A"
                android:textSize="14sp"
                tools:text="FLAC / 38.2 MB / 44.1 kHz / 16 bits / 2 ch / -7.2 dB ReplayGain" />

        </LinearLayout>

        <!-- 歌曲回忆：只显示已结束 session，当前播放中的时长不提前写入。 -->
        <LinearLayout
            android:id="@+id/playerDetailMemoryGroup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvPlayerDetailMemoryTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="歌曲回忆"
                android:textColor="#FF000000"
                android:textSize="16sp"
                tools:text="歌曲回忆" />

            <TextView
                android:id="@+id/tvPlayerDetailMemoryDate"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:textColor="#FF7A7A7A"
                android:textSize="14sp"
                tools:text="2026-04-20 · 21:30" />

            <TextView
                android:id="@+id/tvPlayerDetailMemoryDuration"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textColor="#FF7A7A7A"
                android:textSize="14sp"
                tools:text="听了 3分24秒" />

        </LinearLayout>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
