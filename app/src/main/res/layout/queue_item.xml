<?xml version="1.0" encoding="utf-8"?>
<!--
  播放列表抽屉的单行：小封面 + 歌名 + 歌手
  比主列表紧凑（48dp 封面 / 60dp 行高），因为用户一次要看到更多歌
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="60dp"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:background="?attr/selectableItemBackground"
    android:paddingStart="12dp"
    android:paddingEnd="10dp">

    <ImageView
        android:id="@+id/ivQueueDragHandle"
        android:layout_width="28dp"
        android:layout_height="44dp"
        android:layout_marginEnd="8dp"
        android:paddingStart="4dp"
        android:paddingEnd="4dp"
        android:src="@drawable/ic_drag_two_lines"
        android:scaleType="center"
        android:contentDescription="拖拽排序" />

    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/ivQueueCover"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:background="#FFF2F2F2"
        android:scaleType="centerCrop"
        android:src="@drawable/music_note_24"
        android:contentDescription="cover"
        app:shapeAppearanceOverlay="@style/ShapeCover"
        app:strokeColor="@color/cover_frame_default"
        app:strokeWidth="1.3dp" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:layout_marginStart="12dp"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvQueueTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#FF000000"
            android:textSize="14sp"
            android:singleLine="true"
            android:ellipsize="end"
            tools:text="歌名" />

        <TextView
            android:id="@+id/tvQueueArtist"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#FF888888"
            android:textSize="11sp"
            android:layout_marginTop="2dp"
            android:singleLine="true"
            android:ellipsize="end"
            tools:text="歌手" />
    </LinearLayout>

    <com.example.localmusicapp.WaveBarsView
        android:id="@+id/vQueueWave"
        android:layout_width="18dp"
        android:layout_height="16dp"
        android:layout_marginStart="10dp"
        android:visibility="gone"
        android:contentDescription="正在播放" />

    <ImageButton
        android:id="@+id/btnQueueRemove"
        android:layout_width="40dp"
        android:layout_height="44dp"
        android:layout_marginStart="8dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="从播放队列移除"
        android:padding="8dp"
        android:scaleType="center"
        android:src="@drawable/ic_remove_queue_24" />

</LinearLayout>
