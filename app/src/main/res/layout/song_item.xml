<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="72dp"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:background="@drawable/song_item_touch_bg"
    android:paddingStart="16dp"
    android:paddingEnd="16dp">

    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/ivCover"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:background="#FFF2F2F2"
        android:scaleType="centerCrop"
        android:src="@drawable/music_note_24"
        android:contentDescription="cover"
        app:shapeAppearanceOverlay="@style/ShapeCover"
        app:strokeColor="@color/cover_frame_default"
        app:strokeWidth="1.3dp" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="10dp"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#FF000000"
            android:textSize="15sp"
            android:singleLine="true"
            android:ellipsize="end"
            tools:text="歌名" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tvQualityBadge"
                android:layout_width="wrap_content"
                android:layout_height="16dp"
                android:layout_marginEnd="5dp"
                android:background="@drawable/quality_badge_bg"
                android:gravity="center"
                android:includeFontPadding="false"
                android:minWidth="24dp"
                android:paddingStart="4dp"
                android:paddingEnd="4dp"
                android:textColor="#FF1565C0"
                android:textSize="9sp"
                android:textStyle="bold"
                android:visibility="gone"
                tools:text="SQ"
                tools:visibility="visible" />

            <TextView
                android:id="@+id/tvSubtitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="#FF888888"
                android:textSize="12sp"
                android:singleLine="true"
                android:ellipsize="end"
                tools:text="歌手  ·  专辑名" />
        </LinearLayout>

    </LinearLayout>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <!--
          多选圆圈：平时 GONE；进多选模式时 VISIBLE，同时把下面的 metricIcon/duration 藏掉。
          未选中 = 灰描边空圆；已选中 = 蓝色实心圆 + 白色对勾（两个 drawable 由 Adapter 切换）。
        -->
        <ImageView
            android:id="@+id/ivMultiSelectCheck"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:contentDescription="选中"
            android:src="@drawable/ic_multiselect_circle_empty"
            android:visibility="gone" />

        <ImageView
            android:id="@+id/ivMetricIcon"
            android:layout_width="14dp"
            android:layout_height="14dp"
            android:layout_marginEnd="4dp"
            android:contentDescription="播放次数"
            android:src="@drawable/ic_headphones_24"
            android:tint="#FF888888"
            android:visibility="gone" />

        <TextView
            android:id="@+id/tvDuration"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#FF888888"
            android:textSize="12sp"
            tools:text="03:42" />
    </LinearLayout>

</LinearLayout>
