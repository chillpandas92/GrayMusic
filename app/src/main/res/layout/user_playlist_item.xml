<?xml version="1.0" encoding="utf-8"?>
<!--
  歌单列表的一行：小封面 + 歌单名 + "X首" 副标题。
  高度刻意控制得比收藏夹/听歌排行的两张大卡片小，让它视觉上是"列表条目"而不是"卡片"。
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="56dp"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:background="?attr/selectableItemBackground"
    android:paddingStart="8dp"
    android:paddingEnd="8dp"
    android:clickable="true"
    android:focusable="true">

    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/ivUserPlaylistCover"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:background="#FFF2F2F2"
        android:scaleType="centerCrop"
        android:src="@drawable/music_note_24"
        android:contentDescription="@null"
        app:shapeAppearanceOverlay="@style/ShapeCover"
        app:strokeColor="@color/cover_frame_default"
        app:strokeWidth="1dp" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:layout_marginStart="12dp"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvUserPlaylistName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:singleLine="true"
            android:textColor="#FF000000"
            android:textSize="15sp" />

        <TextView
            android:id="@+id/tvUserPlaylistMeta"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:ellipsize="end"
            android:singleLine="true"
            android:textColor="#FF888888"
            android:textSize="12sp" />
    </LinearLayout>

    <ImageButton
        android:id="@+id/btnUserPlaylistMore"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:src="@drawable/ic_more_vert_24"
        android:scaleType="center"
        android:contentDescription="更多" />

</LinearLayout>
