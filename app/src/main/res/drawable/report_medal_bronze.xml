<?xml version="1.0" encoding="utf-8"?>
<!--
  第三名铜牌：自顶向下的古铜色渐变 + 深铜描边
  用于听歌报告 Top 3 的名次徽章。
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <gradient
        android:angle="270"
        android:startColor="#FFF3C79A"
        android:centerColor="#FFD08A4F"
        android:endColor="#FF8F4A1A"
        android:type="linear" />
    <stroke
        android:width="0.6dp"
        android:color="#FF6B3308" />
    <corners android:radius="999dp" />
</shape>
