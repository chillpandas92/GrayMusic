<?xml version="1.0" encoding="utf-8"?>
<!--
  多选模式下"已选中"的小圆圈：实心深蓝色 + 白色的 check。
  用 layer-list 叠加实心圆和白色对勾。
-->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- 底层：实心圆 -->
    <item>
        <shape android:shape="oval">
            <size
                android:width="22dp"
                android:height="22dp" />
            <solid android:color="#FF1565C0" />
        </shape>
    </item>

    <!-- 顶层：白色对勾（用 vector 画一个），四周留 3dp padding 让对勾不顶边 -->
    <item
        android:drawable="@drawable/ic_multiselect_check_inner"
        android:top="3dp"
        android:bottom="3dp"
        android:start="3dp"
        android:end="3dp" />

</layer-list>
